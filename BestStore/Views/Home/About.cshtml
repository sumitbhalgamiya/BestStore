 @{
    ViewData["Title"] = "About";
}

<div class="container" style="margin-top:30px;">
    
    <div class="panel panel-primary shadow">
        <div class="panel-heading text-center">
            <h2 style="margin:0;">About BestStore</h2>
        </div>

        <div class="panel-body" style="padding:30px;">
            
            <h3 class="text-primary">
                @ViewData["Message"]
            </h3>

            <p style="font-size:16px; line-height:1.8; margin-top:20px;">
                BestStore is your trusted online shopping destination for quality products
                at affordable prices. We provide a seamless shopping experience with a
                wide range of categories including electronics, fashion, accessories,
                and more.
            </p>

            <p style="font-size:16px; line-height:1.8;">
                Our mission is to deliver excellent customer service, fast delivery,
                and the best deals to our customers.
            </p>

            <div class="text-center" style="margin-top:30px;">
                <a asp-controller="Products"
                   asp-action="Index"
                   class="btn btn-success btn-lg">
                    Explore Products
                </a>
            </div>

        </div>
    </div>

</div>