@model BestStore.Models.ProductDto

@{
    ViewData["Title"] = "New Product";
}

<div class="container" style="margin-top:40px;">

    <div class="row justify-content-center">
        
        <div class="col-md-8">

            <div class="panel panel-primary">

                <div class="panel-heading text-center">
                    <h2 style="margin:0;">Add New Product</h2>
                </div>

                <div class="panel-body" style="padding:30px;">

                    <form method="post" enctype="multipart/form-data">

                        <div class="form-group">
                            <label><strong>Product Name</strong></label>

                            <input class="form-control input-lg"
                                   asp-for="Name"
                                   placeholder="Enter product name" />

                            <span asp-validation-for="Name"
                                  class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <label><strong>Brand</strong></label>

                            <input class="form-control input-lg"
                                   asp-for="Brand"
                                   placeholder="Enter brand name" />

                            <span asp-validation-for="Brand"
                                  class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <label><strong>Category</strong></label>

                            <select class="form-control input-lg"
                                    asp-for="Category">

                                <option value="">Select Category</option>
                                <option value="Smartphone">Smartphone</option>
                                <option value="Cellphone">Cellphone</option>
                                <option value="Feature Phones">Feature Phones</option>
                                <option value="Other">Other</option>

                            </select>
                        </div>

                        <div class="form-group">
                            <label><strong>Price</strong></label>

                            <div class="input-group">
                                <span class="input-group-addon">₹</span>

                                <input class="form-control input-lg"
                                       asp-for="Price"
                                       placeholder="Enter price" />
                            </div>

                            <span asp-validation-for="Price"
                                  class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <label><strong>Description</strong></label>

                            <textarea class="form-control"
                                      asp-for="Description"
                                      rows="4"
                                      placeholder="Write product description"></textarea>

                            <span asp-validation-for="Description"
                                  class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <label><strong>Product Image</strong></label>

                            <input type="file"
                                   class="form-control"
                                   asp-for="ImageFile" />

                            <span asp-validation-for="ImageFile"
                                  class="text-danger"></span>
                        </div>

                        <hr />

                        <div class="text-center">

                            <button type="submit"
                                    class="btn btn-success btn-lg"
                                    style="margin-right:10px;">
                                Save Product
                            </button>

                            <a class="btn btn-default btn-lg"
                               asp-controller="Products"
                               asp-action="Index">
                                Cancel
                            </a>

                        </div>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>